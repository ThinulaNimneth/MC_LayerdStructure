<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f5f7fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.medicalcenterlayerdstructure.controller.DashboardHomeController">
    <content>
        <AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f5f7fa;">
            <children>

                <HBox alignment="CENTER" layoutX="168.0" prefHeight="50.0" prefWidth="450.0" spacing="20.0" style="-fx-background-color: #2196F3; -fx-background-radius: 25;">
                    <children>
                        <VBox alignment="CENTER" spacing="3.0">
                            <children>
                                <Label text="Medical Center Dashboard" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <HBox alignment="CENTER" spacing="12.0" />
                            </children>
                        </VBox>
                    </children>
                </HBox>


                <HBox alignment="CENTER" layoutX="30.0" layoutY="85.0" prefHeight="110.0" prefWidth="740.0" spacing="25.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="150.0" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #4ED7F1; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;" text="Total Patients" />
                                <Label fx:id="lblTotalPatients" text="0" textFill="#4ED7F1">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblPatientTrend" style="-fx-font-size: 9px; -fx-text-fill: #27AE60;" text="📈 Registered" />
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                            </padding>
                        </VBox>


                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="150.0" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #4ED7F1; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;" text="Appointments Today" />
                                <Label fx:id="lblTodayAppointments" text="0" textFill="#4ED7F1">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                                <Label fx:id="lblAppointmentTrend" style="-fx-font-size: 9px; -fx-text-fill: #27AE60;" text="📅 Scheduled" />
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                            </padding>
                        </VBox>


                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="150.0" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #4ED7F1; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;" text="Active Doctors" />
                                <Label fx:id="lblActiveDoctors" text="0/0" textFill="#4ED7F1">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                                <Label style="-fx-font-size: 9px; -fx-text-fill: #7F8C8D;" text="👨‍⚕️ Available" />
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>


                <HBox alignment="CENTER" layoutX="30.0" layoutY="210.0" prefHeight="110.0" prefWidth="740.0" spacing="25.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="150.0" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #F39C12; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;" text="Today's Revenue" />
                                <Label fx:id="lblTodayRevenue" text="Rs. 0" textFill="#F39C12">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label style="-fx-font-size: 9px; -fx-text-fill: #27AE60;" text="💰 Collected" />
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                            </padding>
                        </VBox>


                        <VBox alignment="CENTER" prefHeight="110.0" prefWidth="150.0" spacing="4.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E74C3C; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                            <children>
                                <Label style="-fx-font-size: 11px; -fx-text-fill: #7F8C8D;" text="Low Stock Items" />
                                <Label fx:id="lblLowStockMedicines" text="0" textFill="#E74C3C">
                                    <font>
                                        <Font name="System Bold" size="30.0" />
                                    </font>
                                </Label>
                                <Label style="-fx-font-size: 9px; -fx-text-fill: #E74C3C;" text="💊 Alert" />
                            </children>
                            <padding>
                                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
                            </padding>
                        </VBox>
                    </children>
                </HBox>


                <VBox layoutX="30.0" layoutY="335.0" prefHeight="250.0" prefWidth="740.0" spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 18; -fx-border-color: #4ED7F1; -fx-border-radius: 10; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 8, 0, 0, 2);">
                    <children>
                        <Label text="📅 Today's Appointments" textFill="#4ED7F1">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <TableView fx:id="tblTodayAppointments" prefHeight="195.0" prefWidth="700.0">
                            <columns>
                                <TableColumn fx:id="colAppointmentId" prefWidth="45.0" text="ID" />
                                <TableColumn fx:id="colPatientName" prefWidth="145.0" text="Patient" />
                                <TableColumn fx:id="colDoctorName" prefWidth="145.0" text="Doctor" />
                                <TableColumn fx:id="colTime" prefWidth="75.0" text="Time" />
                                <TableColumn fx:id="colAmount" prefWidth="95.0" text="Amount (Rs)" />
                                <TableColumn fx:id="colStatus" prefWidth="115.0" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </content>
</ScrollPane>
