<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane fx:id="doctorContent" prefHeight="600.0" prefWidth="824.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="lk.ijse.medicalcenterlayerdstructure.controller.DoctorController">

   <children>

      <VBox alignment="CENTER" layoutX="187.0" prefHeight="50.0" prefWidth="450.0" style="-fx-background-color: #2196F3; -fx-background-radius: 25;">
         <children>
            <Text fill="WHITE" strokeType="OUTSIDE" strokeWidth="0.0" text="Doctor Management">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Text>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>


      <VBox layoutX="14.0" layoutY="74.0" prefHeight="230.0" prefWidth="796.0" spacing="8.0" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-border-color: #B3D9FF; -fx-border-radius: 10; -fx-border-width: 2;">
         <padding>
            <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
         </padding>

         <children>
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2196F3;" text="Doctor Information">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Label>


            <HBox spacing="15.0">
               <children>
                  <VBox prefWidth="380.0" spacing="6.0">
                     <children>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="Doctor ID:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtDoctorId" editable="false" prefWidth="220.0" style="-fx-background-color: #f0f0f0;" />
                           </children>
                        </HBox>


                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="User ID:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtUserId" editable="false" prefWidth="220.0" style="-fx-background-color: #f0f0f0;" />
                           </children>
                        </HBox>


                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="Search by ID:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtSearchById" prefWidth="220.0" promptText="Enter doctor ID" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox prefWidth="380.0" spacing="6.0">
                     <children>

                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="Doctor Name:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtDoctorName" prefWidth="220.0" promptText="Enter doctor name" />
                           </children>
                        </HBox>


                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="Specialization:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="txtSpecialization" prefWidth="220.0" promptText="e.g., Cardiology" />
                           </children>
                        </HBox>


                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                           <children>
                              <Label prefWidth="100.0" text="Availability:">
                                 <font>
                                    <Font name="System Bold" size="11.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="cmbAvailability" prefWidth="220.0" promptText="Select availability" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>


            <HBox alignment="CENTER_LEFT" spacing="8.0" style="-fx-padding: 8 0 0 0;">
               <children>
                  <Label prefWidth="100.0" text="Search by Name:">
                     <font>
                        <Font name="System Bold" size="11.0" />
                     </font>
                  </Label>
                  <TextField fx:id="txtSearchByName" prefWidth="380.0" promptText="Enter doctor name" />
               </children>
            </HBox>


            <HBox alignment="CENTER" spacing="15.0" style="-fx-padding: 12 0 0 0;">
               <children>
                  <Button fx:id="btnSave" onAction="#handleSave" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Save">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnUpdate" onAction="#handleUpdate" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #6F42C1; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Update">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnDelete" onAction="#handleDelete" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #B22222; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Delete">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button fx:id="btnClear" onAction="#handleClear" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Clear">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
                  <Button onAction="#handleSearchById" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="Search ID">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>


      <VBox layoutX="14.0" layoutY="314.0" prefHeight="272.0" prefWidth="796.0" spacing="4.0">
         <children>
            <Label style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #2196F3;" text="Registered Doctors" />

            <TableView fx:id="tblDoctors" prefHeight="242.0" prefWidth="796.0">
               <columns>
                  <TableColumn fx:id="colDoctorId" prefWidth="70.0" text="Doctor ID" />
                  <TableColumn fx:id="colDoctorName" prefWidth="230.0" text="Doctor Name" />
                  <TableColumn fx:id="colSpecialization" prefWidth="230.0" text="Specialization" />
                  <TableColumn fx:id="colAvailability" prefWidth="130.0" text="Availability" />
               </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>
